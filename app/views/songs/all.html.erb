<div class="page-header">
  <h1>All Songs</h1>
</div>

<% if @bands_with_songs.any? %>
  <div class="cross-band-list">
    <% @bands_with_songs.each do |band| %>
      <div class="cross-band-section">
        <div class="cross-band-header">
          <h2><%= link_to band.name, band_path(band), class: "cross-band-name" %></h2>
          <%= link_to "Add Song", new_band_song_path(band), class: "btn btn-sm btn-primary" %>
        </div>

        <% if band.songs.any? %>
          <div class="item-list">
            <% band.songs.each do |song| %>
              <div class="item-row">
                <div class="item-row-main">
                  <span class="item-title"><%= song.title %></span>
                  <% if song.duration_formatted %>
                    <span class="song-duration"><%= song.duration_formatted %></span>
                  <% end %>
                </div>
                <div class="row-actions">
                  <%= link_to "Edit", edit_band_song_path(band, song), class: "btn btn-sm btn-secondary" %>
                  <%= button_to "Delete", band_song_path(band, song), method: :delete,
                      data: { turbo_confirm: "Delete \"#{song.title}\"?" },
                      class: "btn btn-sm btn-danger" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-light cross-band-empty">No songs yet.</p>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <p>You're not in any bands yet.</p>
    <%= link_to "Create a band", new_band_path, class: "btn btn-primary" %>
  </div>
<% end %>
