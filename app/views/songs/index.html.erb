<div class="page-header">
  <h1>Songs — <%= @band.name %></h1>
  <%= link_to "Add Song", new_band_song_path(@band), class: "btn btn-primary" %>
</div>

<% if @songs.any? %>
  <div class="item-list">
    <% @songs.each do |song| %>
      <div class="item-row">
        <div style="display: flex; align-items: center; gap: 12px; min-width: 0;">
          <span style="font-weight: 600; font-size: 0.9375rem;"><%= song.title %></span>
          <% if song.duration_formatted %>
            <span class="badge" style="font-size: 0.75rem; font-weight: 600; font-variant-numeric: tabular-nums;">⏱ <%= song.duration_formatted %></span>
          <% end %>
        </div>
        <div class="row-actions">
          <%= link_to "Edit", edit_band_song_path(@band, song), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", band_song_path(@band, song), method: :delete,
              data: { turbo_confirm: "Delete \"#{song.title}\"?" }, class: "btn btn-sm btn-danger" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <p>No songs yet.</p>
    <%= link_to "Add your first song", new_band_song_path(@band), class: "btn btn-primary" %>
  </div>
<% end %>
