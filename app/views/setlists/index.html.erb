<div class="page-header">
  <h1>Setlists — <%= @band.name %></h1>
  <%= link_to "New Setlist", new_band_setlist_path(@band), class: "btn btn-primary" %>
</div>
<% if @setlists.any? %>
  <ul class="item-list">
    <% @setlists.each do |setlist| %>
      <li class="item-row">
        <%= link_to setlist.name, setlist_path(setlist) %>
        <div class="row-actions">
          <%= link_to "Open", setlist_path(setlist), class: "btn btn-sm btn-primary" %>
          <%= link_to "Edit", edit_setlist_path(setlist), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", band_setlist_path(@band, setlist), method: :delete,
              data: { turbo_confirm: "Delete \"#{setlist.name}\"?" }, class: "btn btn-sm btn-danger" %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="empty-state"><p>No setlists yet.</p></div>
<% end %>
