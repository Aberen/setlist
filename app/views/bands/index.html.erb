<div class="page-header">
  <h1>My Bands</h1>
  <%= link_to "New Band", new_band_path, class: "btn btn-primary" %>
</div>

<% if @bands.any? %>
  <div class="band-list">
    <% @bands.each do |band| %>
      <div class="band-card">
        <div class="band-card-info">
          <h2><%= link_to band.name, band_path(band) %></h2>
          <span class="text-muted"><%= band.members.count %> members &middot; <%= band.songs.count %> songs</span>
          <% if band.owner?(current_user) %><span class="badge badge-owner">Owner</span><% end %>
        </div>
        <div class="band-card-actions">
          <%= link_to "View", band_path(band), class: "btn btn-sm btn-secondary" %>
          <% if band.owner?(current_user) %>
            <%= link_to "Edit", edit_band_path(band), class: "btn btn-sm btn-secondary" %>
            <%= button_to "Delete", band_path(band), method: :delete,
                data: { turbo_confirm: "Delete #{band.name}?" }, class: "btn btn-sm btn-danger" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <p>You're not in any bands yet.</p>
    <%= link_to "Create your first band", new_band_path, class: "btn btn-primary" %>
  </div>
<% end %>
